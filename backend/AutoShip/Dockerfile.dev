# ============================
# SDK IMAGE (runtime + build)
# ============================
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS final
WORKDIR /app

# Copy everything (source code)
COPY . .

# Install EF tools
RUN dotnet tool install --global dotnet-ef
ENV PATH="$PATH:/root/.dotnet/tools"

# Restore & publish
RUN dotnet restore
RUN dotnet publish -c Release -o /app/publish

# Expose backend port
EXPOSE 5000
ENV ASPNETCORE_URLS=http://0.0.0.0:5000

# Run migrations from SOURCE folder, then run app from PUBLISH folder
ENTRYPOINT ["bash", "-c", "cd /app && dotnet ef database update && dotnet /app/publish/AutoShip.dll"]

